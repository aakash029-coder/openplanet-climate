# ──────────────────────────────────────────────────────────────────────────────
# OpenPlanet Climate Risk Engine — Environment Variable Reference
# Copy this file to .env (backend) and frontend/.env.local (frontend).
# Never commit files containing real credentials.
# ──────────────────────────────────────────────────────────────────────────────

# ── BACKEND: climate_engine ───────────────────────────────────────────────────

# Groq LLM API key — used for AI narrative generation in /api/research-analysis
GROQ_API_KEY=gsk_your_groq_api_key_here

# ECMWF CDS credentials — optional, for direct ERA5 download outside Open-Meteo
ECMWF_UID=your_ecmwf_uid
ECMWF_API_KEY=your_ecmwf_api_key

# NASA Earthdata credentials — optional, for satellite land-cover overlays
NASA_EARTHDATA_USERNAME=your_nasa_username
NASA_EARTHDATA_PASSWORD=your_nasa_password

# Google Earth Engine service account — optional, for GEE-backed spatial layers
GEE_SERVICE_ACCOUNT_EMAIL=your-service-account@your-project.iam.gserviceaccount.com
GEE_SERVICE_ACCOUNT_FILE=secrets/gee-service-account.json
GEE_PROJECT_ID=your-gee-project-id

# API key protection for engine endpoints (comma-separated; empty = disabled in dev)
API_KEYS=

# CORS — set to your frontend origin in production
CORS_ORIGINS=http://localhost:3000

# Secret key for signing internal tokens — minimum 32 characters in production
SECRET_KEY=change_this_to_a_strong_random_secret_min_32_chars

# Runtime mode: development | production
ENV_MODE=development
LOG_LEVEL=INFO

# Rate limiting (requests per minute per IP)
RATE_LIMIT_PER_MINUTE=100

# ── FRONTEND: Next.js ─────────────────────────────────────────────────────────

# Base URL of the running FastAPI engine (no trailing slash)
# Local dev:      http://localhost:7860
# Hugging Face:   https://albus2903-openplanet-engine.hf.space
NEXT_PUBLIC_ENGINE_URL=http://localhost:7860

# MapLibre / MapTiler API key — required for the base map tile layer
NEXT_PUBLIC_MAPTILER_KEY=your_maptiler_key_here

# NextAuth secret — used for session signing (generate with: openssl rand -hex 32)
NEXTAUTH_SECRET=your_nextauth_secret_here
NEXTAUTH_URL=http://localhost:3000
